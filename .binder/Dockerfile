# Binder launcher for Underworld3 - v3.0.0 release
# Uses pre-built base image from GHCR
# This is a frozen release — the image tag will not change.
#
# Direct launch:
#   https://mybinder.org/v2/gh/underworldcode/uw3-binder-launcher/v3.0.0

FROM ghcr.io/underworldcode/uw3-base:v3.0.0-slim

ENV UW3_BRANCH=v3.0.0
